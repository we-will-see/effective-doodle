#!/bin/bash
# Google Workspace (gog) Environment
# Usage: source /root/.openclaw/workspace/.env_gog

# Keyring password (trimmed, no newline)
export GOG_KEYRING_PASSWORD="$(tr -d '\n' < /root/.config/gog/keyring.pwd)"

# Default account
export GOG_ACCOUNT="the17virus@gmail.com"

# Optional: Services filter
# export GOG_SERVICES="gmail,calendar,drive,sheets,docs"
